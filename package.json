{
  "name": "ustc-payment-portal-dev-dashboard",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:test": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "npm run test:e2e",
    "test:e2e": "npm run build && start-server-and-test preview:test http://127.0.0.1:4173 cypress:run",
    "test:e2e:open": "npm run build && start-server-and-test preview:test http://127.0.0.1:4173 cypress:open",
    "test:coverage": "npm run test:e2e",
    "tsc": "tsc"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-data-grid": "^8.27.3",
    "dayjs": "^1.11.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cypress": "^15.11.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "start-server-and-test": "^2.0.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
